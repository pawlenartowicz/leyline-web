   - "Also a website"                     : "1-what-is-leyline/web-preview"

"Features" : "2-features"
   - "Markdown rendering"     : "2-features/markdown"
   - "Themes"                 : "2-features/themes"
   - "History and tagging"    : "2-features/history-and-tagging"
   - "Editing in the browser" : "2-features/editing-online"
   - "LaTeX and Typst"        : "2-features/latex-and-typst"

"How to run it" : "3-how-to-run-it"
   - "Install and run"          : "3-how-to-run-it/install-and-run"
   - "Connect your first vault" : "3-how-to-run-it/first-vault"
